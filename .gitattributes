# Detecta arquivos de texto automaticamente
* text=auto

# Kotlin / Java
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf

# XML
*.xml text eol=lf

# Gradle
*.gradle text eol=lf
*.properties text eol=lf

# Markdown
*.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Imagens
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg text

# Banco de dados
*.db binary

# APK
*.apk binary